# ====================
#   Ghostty Config # JetBrainsMono - CaskaydiaCove
# ====================
font-family = JetBrainsMono Nerd Font  
font-size = 15

#[ Cursor - #FFFF33 - #00CCFF - #FF073A - #39FF14 - #B026FF]
cursor-color = #39FF14
cursor-text = #000000
cursor-style = block
cursor-style-blink = true

background-opacity = 0.90

window-padding-x = 5
window-padding-y = 5

#[ MISC ]
shell-integration = detect
bell-features = title
 
gtk-single-instance = true
window-decoration = false
confirm-close-surface = false

#[ THEMES - axgruv - mono - Vesper - - Mathias ] 
theme = "Gruvbox Dark Hard"
# theme = "Matte Black"
# theme = "Builtin Pastel Dark"
# theme = ""

#[ Shaders_Main ]
custom-shader-animation = always
custom-shader = ./shaders/cursor_blaze_no_trail.glsl
custom-shader = ./shaders/ripple_rectangle_cursor.glsl
custom-shader = ./shaders/cursor_warp.glsl
custom-shader = ./shaders/cursor_smear_fade.glsl


# [ Keybindings ]
keybind = ctrl+space>r=reload_config

keybind = ctrl+space>n=new_window
keybind = ctrl+space>t=new_tab
keybind = ctrl+space>q=close_tab

#keybind = shift+alt+h=previous_tab
#keybind = shift+alt+l=next_tab

